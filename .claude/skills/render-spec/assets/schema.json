{
  "type": "object",
  "required": ["id", "layer", "purpose", "rules"],
  "properties": {
    "id": {
      "type": "string"
    },
    "layer": {
      "type": "string",
      "enum": [
        "language",
        "platform",
        "interface",
        "presentation",
        "delivery",
        "observability",
        "security",
        "practices",
        "quality"
      ]
    },
    "purpose": {
      "type": "string"
    },
    "extends": {
      "type": "array",
      "items": { "type": "string" }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "ref"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["spec", "adr", "bdr", "external"]
          },
          "ref": {
            "type": "string",
            "description": "Identifier, path, or URL"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["statement"],
        "properties": {
          "statement": {
            "type": "string"
          },
          "references": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional links to supporting references"
          }
        }
      }
    }
  }
}
